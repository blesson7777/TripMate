DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.example.com,server-ip-or-sslip-domain
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example.com,https://server-ip-or-sslip-domain
DJANGO_TIME_ZONE=Asia/Kolkata
DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

DB_NAME=tripmate_db
DB_USER=tripmate_user
DB_PASSWORD=replace-with-your-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_HOST_USER=your-email@example.com
DJANGO_EMAIL_HOST_PASSWORD=your-email-app-password
DJANGO_DEFAULT_FROM_EMAIL=your-email@example.com

FCM_SERVER_KEY=
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_FILE=/home/ubuntu/tripmate-backend/fcm-service-account.json
FCM_SERVICE_ACCOUNT_JSON=

OTP_EXPIRY_MINUTES=10

# Extra protection for /admin/server-health/.
# If set, admins must enter this password to open the Server Health page.
SERVER_HEALTH_PASSWORD=Ammu@1248
# Optional alternative to plaintext password: a Django password hash (preferred).
# Generate with: from django.contrib.auth.hashers import make_password
SERVER_HEALTH_PASSWORD_HASH=
SERVER_HEALTH_UNLOCK_TTL_MINUTES=30
