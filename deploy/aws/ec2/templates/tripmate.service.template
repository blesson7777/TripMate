[Unit]
Description=TripMate Django Gunicorn Service
After=network.target

[Service]
User=__APP_USER__
Group=__APP_GROUP__
WorkingDirectory=__APP_DIR__
EnvironmentFile=__APP_DIR__/.env
Environment=DJANGO_SETTINGS_MODULE=tripmate.settings
ExecStart=__APP_DIR__/venv/bin/gunicorn tripmate.wsgi:application --bind __BIND_ADDRESS__:__BIND_PORT__ --workers __WORKERS__ --timeout 120
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
